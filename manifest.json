{
    "manifest_version": 3,
    "name": "WhatsApp Auto Caps & Punctuate",
    "version": "1.0",
    "description": "Auto capitalize and punctuate messages in WhatsApp Web",
    "permissions": ["scripting"],
    "host_permissions": ["https://web.whatsapp.com/*"],
    "content_scripts": [
        {
            "matches": ["https://web.whatsapp.com/*"],
            "js": ["content.js"]
        }
    ]
}
